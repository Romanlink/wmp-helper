# ============================================================
# 后端 helper（Spring Boot / Maven）忽略规则
# ============================================================

# ===================== 构建产物 =====================
target/
*.class
*.jar
*.war
*.ear

# Maven Wrapper 缓存（仅忽略下载的 jar，保留 wrapper 配置与脚本）
.mvn/wrapper/maven-wrapper.jar

# ===================== 运行时 / 上传目录 =====================
# 运行时生成的用户上传文件，保留空目录占位（.gitkeep）
# 注意：必须忽略目录内的内容（uploads/*）而非整个目录，
# 否则无法用 !uploads/.gitkeep 重新纳入占位文件
uploads/*
!uploads/.gitkeep

# ===================== 日志 =====================
*.log

# ===================== 依赖 / 本地仓库 =====================
# 若项目内存在本地 Maven 仓库（一般不会），忽略之
.m2/

# ===================== IDE =====================
.idea/
*.iws
*.iml
*.ipr
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ===================== 编辑器 / 临时 =====================
*.swp
*~
*.swo

# ===================== 操作系统 =====================
.DS_Store
Thumbs.db
